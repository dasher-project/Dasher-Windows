<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Dasher.Windows.App"
             xmlns:local="using:Dasher.Windows"
             RequestedThemeVariant="Default">

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <!-- Light theme -->
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="DasherTeal" Color="#99D4CD"/>
                    <SolidColorBrush x:Key="WarmYellow" Color="#F8E063"/>
                    <SolidColorBrush x:Key="CoralRed" Color="#EB5B5C"/>
                    <SolidColorBrush x:Key="DeepNavy" Color="#0F4B75"/>

                    <SolidColorBrush x:Key="BgLight" Color="#F4F7F6"/>
                    <SolidColorBrush x:Key="SurfaceLight" Color="#FFFFFF"/>
                    <SolidColorBrush x:Key="BorderLight" Color="#E0E6E8"/>
                    <SolidColorBrush x:Key="HighlightLight" Color="#E9F2F1"/>

                    <SolidColorBrush x:Key="TextPrimary" Color="#0F4B75"/>
                    <SolidColorBrush x:Key="TextSecondary" Color="#5A6270"/>
                    <SolidColorBrush x:Key="TextMuted" Color="#8B929A"/>

                    <SolidColorBrush x:Key="ControlBg" Color="#ECECED"/>
                    <SolidColorBrush x:Key="ControlBgHover" Color="#E0E0E1"/>
                    <SolidColorBrush x:Key="ControlValue" Color="#F4F0F0"/>
                </ResourceDictionary>

                <!-- Dark theme -->
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="DasherTeal" Color="#5BB8B0"/>
                    <SolidColorBrush x:Key="WarmYellow" Color="#F8E063"/>
                    <SolidColorBrush x:Key="CoralRed" Color="#EB5B5C"/>
                    <SolidColorBrush x:Key="DeepNavy" Color="#7AB8E0"/>

                    <SolidColorBrush x:Key="BgLight" Color="#1A1D1E"/>
                    <SolidColorBrush x:Key="SurfaceLight" Color="#25282B"/>
                    <SolidColorBrush x:Key="BorderLight" Color="#3A3F44"/>
                    <SolidColorBrush x:Key="HighlightLight" Color="#1E3331"/>

                    <SolidColorBrush x:Key="TextPrimary" Color="#E0E6E8"/>
                    <SolidColorBrush x:Key="TextSecondary" Color="#9CA3AF"/>
                    <SolidColorBrush x:Key="TextMuted" Color="#6B7280"/>

                    <SolidColorBrush x:Key="ControlBg" Color="#353839"/>
                    <SolidColorBrush x:Key="ControlBgHover" Color="#404348"/>
                    <SolidColorBrush x:Key="ControlValue" Color="#3A3D42"/>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>

            <!-- Shared (theme-independent) resources -->
            <x:Double x:Key="SpacingXs">4</x:Double>
            <x:Double x:Key="SpacingSm">8</x:Double>
            <x:Double x:Key="SpacingMd">16</x:Double>
            <x:Double x:Key="SpacingLg">24</x:Double>
            <x:Double x:Key="SpacingXl">32</x:Double>

            <CornerRadius x:Key="RadiusSm">4</CornerRadius>
            <CornerRadius x:Key="RadiusMd">8</CornerRadius>
            <CornerRadius x:Key="RadiusLg">12</CornerRadius>

            <x:Double x:Key="TouchTarget">48</x:Double>
            <x:Double x:Key="ToolbarHeight">64</x:Double>
            <x:Double x:Key="StatusBarHeight">48</x:Double>
        </ResourceDictionary>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />
    </Application.Styles>
</Application>
