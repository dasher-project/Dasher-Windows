<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Dasher.Windows.ViewModels"
        xmlns:controls="using:Dasher.Windows.Controls"
        xmlns:lucide="using:Lucide.Avalonia"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1024" d:DesignHeight="768"
        x:Class="Dasher.Windows.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Dasher"
        Width="1024" Height="768"
        MinWidth="600" MinHeight="500"
        Background="{DynamicResource BgLight}"
        WindowStartupLocation="CenterScreen"
        Icon="/dasher.ico">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Window.Styles>
        <Style Selector="Border.top-bar">
            <Setter Property="Background" Value="{DynamicResource SurfaceLight}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderLight}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Height" Value="84"/>
            <Setter Property="Padding" Value="16,0"/>
        </Style>

        <Style Selector="Border.top-bar Button.nav-btn">
            <Setter Property="Width" Value="56"/>
            <Setter Property="Height" Value="52"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Border.top-bar Button.nav-btn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource ControlBgHover}"/>
        </Style>
        <Style Selector="Border.top-bar Button.nav-btn LucideIcon">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
        </Style>
        <Style Selector="Border.top-bar Button.nav-btn.accent /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource DasherTeal}"/>
        </Style>
        <Style Selector="Border.top-bar Button.nav-btn.accent TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource DeepNavy}"/>
        </Style>
        <Style Selector="Border.top-bar Button.nav-btn.accent LucideIcon">
            <Setter Property="Foreground" Value="{DynamicResource DeepNavy}"/>
        </Style>

        <Style Selector="Button.ui-circle-btn">
            <Setter Property="Width" Value="44"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Background" Value="{DynamicResource ControlBg}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="22"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.ui-circle-btn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource ControlBgHover}"/>
        </Style>

        <Style Selector="Button.ui-step-btn">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="600"/>
            <Setter Property="MinWidth" Value="28"/>
            <Setter Property="MinHeight" Value="28"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.ui-step-btn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource ControlBgHover}"/>
        </Style>

        <Style Selector="Border.prefs-bar">
            <Setter Property="Background" Value="{DynamicResource SurfaceLight}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderLight}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="16,0"/>
        </Style>
        <Style Selector="Border.prefs-bar Button.prefs-tab">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="500"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="CornerRadius" Value="{DynamicResource RadiusSm}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Border.prefs-bar Button.prefs-tab:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource ControlBg}"/>
        </Style>
        <Style Selector="Border.prefs-bar Button.prefs-tab.active /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource ControlBg}"/>
        </Style>
        <Style Selector="Border.prefs-bar Button.prefs-tab.active TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style Selector="TextBlock.ui-nav-label">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="500"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMuted}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style Selector="ComboBox.ui-lang-select">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="500"/>
            <Setter Property="MinHeight" Value="28"/>
            <Setter Property="MinWidth" Value="140"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.ui-colour-dot">
            <Setter Property="Width" Value="14"/>
            <Setter Property="Height" Value="14"/>
            <Setter Property="CornerRadius" Value="7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderLight}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
        <Style Selector="Button.ui-colour-dot.selected">
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="BorderBrush" Value="{DynamicResource DeepNavy}"/>
        </Style>

        <Style Selector="GridSplitter.pane-splitter">
            <Setter Property="Background" Value="{DynamicResource BorderLight}"/>
            <Setter Property="ResizeBehavior" Value="PreviousAndNext"/>
            <Setter Property="MinWidth" Value="5"/>
            <Setter Property="MinHeight" Value="5"/>
        </Style>
        <Style Selector="GridSplitter.pane-splitter:pointerover">
            <Setter Property="Background" Value="{DynamicResource DasherTeal}"/>
        </Style>

        <Style Selector="Border.bottom-bar">
            <Setter Property="Background" Value="{DynamicResource SurfaceLight}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderLight}"/>
            <Setter Property="BorderThickness" Value="0,1,0,0"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Padding" Value="16,0"/>
        </Style>

        <Style Selector="TextBox.message-area">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontFamily" Value="Arial, Segoe UI, Helvetica Neue, sans-serif"/>
            <Setter Property="AcceptsReturn" Value="True"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16"/>
        </Style>
    </Window.Styles>

    <DockPanel>
        <Border Classes="top-bar" DockPanel.Dock="Top">
            <Grid ColumnDefinitions="*, Auto">
                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center" HorizontalAlignment="Left">
                    <Button Classes="nav-btn" Click="OnNew" ToolTip.Tip="New document">
                        <StackPanel Spacing="3">
                            <LucideIcon Kind="{x:Static lucide:LucideIconKind.FilePlus}" Size="20"/>
                            <TextBlock Text="New" FontSize="11" FontWeight="Medium" HorizontalAlignment="Center" Foreground="{DynamicResource TextSecondary}"/>
                        </StackPanel>
                    </Button>

                    <Button Classes="nav-btn" Click="OnOpen" ToolTip.Tip="Open file">
                        <StackPanel Spacing="3">
                            <LucideIcon Kind="{x:Static lucide:LucideIconKind.FolderOpen}" Size="20"/>
                            <TextBlock Text="Open" FontSize="11" FontWeight="Medium" HorizontalAlignment="Center" Foreground="{DynamicResource TextSecondary}"/>
                        </StackPanel>
                    </Button>

                    <Button Classes="nav-btn" Click="OnSave" ToolTip.Tip="Save file">
                        <StackPanel Spacing="3">
                            <LucideIcon Kind="{x:Static lucide:LucideIconKind.Save}" Size="20"/>
                            <TextBlock Text="Save" FontSize="11" FontWeight="Medium" HorizontalAlignment="Center" Foreground="{DynamicResource TextSecondary}"/>
                        </StackPanel>
                    </Button>

                    <Rectangle Width="1" Height="24" Fill="{DynamicResource BorderLight}" Margin="6,0"/>

                    <Button x:Name="BtnMode" Classes="nav-btn" Width="120" ToolTip.Tip="Pane position">
                        <Button.Flyout>
                            <MenuFlyout>
                                <MenuItem Header="Right side" Click="OnModeRightSide"/>
                                <MenuItem Header="Left side" Click="OnModeLeftSide"/>
                                <MenuItem Header="Bottom" Click="OnModeBottom"/>
                                <MenuItem Header="Top" Click="OnModeTop"/>
                                <MenuItem Header="Keyboard" Click="OnModeKeyboard"/>
                            </MenuFlyout>
                        </Button.Flyout>
                        <StackPanel Spacing="3">
                            <LucideIcon x:Name="ModeIcon" Kind="{x:Static lucide:LucideIconKind.PanelRight}" Size="20"/>
                            <StackPanel Orientation="Horizontal" Spacing="2" HorizontalAlignment="Center">
                                <TextBlock Name="TxtModeLabel" Text="Right side" FontSize="11" FontWeight="Medium" Foreground="{DynamicResource TextSecondary}"/>
                                <TextBlock Text="▾" FontSize="11" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </Button>

                    <Rectangle Width="1" Height="24" Fill="{DynamicResource BorderLight}" Margin="6,0"/>

                    <Button x:Name="BtnKeyboard" Classes="nav-btn" Click="OnToggleMode" ToolTip.Tip="Toggle keyboard mode">
                        <StackPanel Spacing="3">
                            <LucideIcon Kind="{x:Static lucide:LucideIconKind.Keyboard}" Size="20"/>
                            <TextBlock x:Name="TxtKeyboardLabel" Text="Keyboard" FontSize="11" FontWeight="Medium" HorizontalAlignment="Center" Foreground="{DynamicResource TextSecondary}"/>
                        </StackPanel>
                    </Button>

                    <Rectangle Width="1" Height="24" Fill="{DynamicResource BorderLight}" Margin="6,0"/>

                    <Button x:Name="BtnGameMode" Classes="nav-btn" Click="OnToggleGameMode" ToolTip.Tip="Toggle game mode">
                        <StackPanel Spacing="3">
                            <LucideIcon x:Name="GameIcon" Kind="{x:Static lucide:LucideIconKind.Gamepad2}" Size="20"/>
                            <TextBlock x:Name="TxtGameLabel" Text="Game" FontSize="11" FontWeight="Medium" HorizontalAlignment="Center" Foreground="{DynamicResource TextSecondary}"/>
                        </StackPanel>
                    </Button>

                    <Rectangle Width="1" Height="24" Fill="{DynamicResource BorderLight}" Margin="6,0"/>

                    <Button x:Name="BtnControlMode" Classes="nav-btn" Click="OnToggleControlMode" ToolTip.Tip="Toggle control mode">
                        <StackPanel Spacing="3">
                            <LucideIcon Kind="{x:Static lucide:LucideIconKind.MousePointerClick}" Size="20"/>
                            <TextBlock x:Name="TxtControlLabel" Text="Control" FontSize="11" FontWeight="Medium" HorizontalAlignment="Center" Foreground="{DynamicResource TextSecondary}"/>
                        </StackPanel>
                    </Button>

                    <Rectangle Width="1" Height="24" Fill="{DynamicResource BorderLight}" Margin="6,0"/>

                    <Button x:Name="BtnPrefs" Classes="nav-btn" Click="OnTogglePrefs" ToolTip.Tip="Preferences">
                        <StackPanel Spacing="3">
                            <LucideIcon Kind="{x:Static lucide:LucideIconKind.Settings}" Size="20"/>
                            <TextBlock Text="Prefs" FontSize="11" FontWeight="Medium" HorizontalAlignment="Center" Foreground="{DynamicResource TextSecondary}"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center" HorizontalAlignment="Right">
                </StackPanel>
            </Grid>
        </Border>

        <StackPanel DockPanel.Dock="Top" IsVisible="{Binding IsPrefsVisible}">
            <Border Classes="prefs-bar">
                <Border x:Name="PrefsTabStrip" IsVisible="True">
                    <StackPanel x:Name="PrefsTabContainer" Orientation="Horizontal" Spacing="2" VerticalAlignment="Center"/>
                </Border>
            </Border>
            <Border x:Name="PrefsContentPanel" Classes="prefs-content" IsVisible="False"
                    Background="{DynamicResource BgLight}" BorderBrush="{DynamicResource BorderLight}" BorderThickness="0,0,0,1"
                    MaxHeight="320">
                <controls:SettingsPanel x:Name="SettingsPanel"/>
            </Border>
        </StackPanel>

        <Border x:Name="StatusBarShowBtn" DockPanel.Dock="Bottom" IsVisible="{Binding IsStatusBarHidden}"
                Background="Transparent" Padding="4">
            <Button Width="28" Height="20" CornerRadius="6" Background="{DynamicResource ControlBg}" BorderThickness="0"
                    HorizontalAlignment="Center" Click="OnToggleStatusBar"
                    ToolTip.Tip="Show status bar">
                <LucideIcon Kind="{x:Static lucide:LucideIconKind.ChevronUp}" Size="16" Foreground="{DynamicResource TextMuted}"/>
            </Button>
        </Border>

        <Border x:Name="BottomBar" Classes="bottom-bar" DockPanel.Dock="Bottom" IsVisible="{Binding !IsStatusBarHidden}">
            <StackPanel Orientation="Horizontal" Spacing="0" VerticalAlignment="Center">
                <Button Width="32" Height="32" CornerRadius="16" Background="{DynamicResource ControlBg}" BorderThickness="0"
                        VerticalAlignment="Center" Click="OnBack" ToolTip.Tip="Back">
                    <LucideIcon Kind="{x:Static lucide:LucideIconKind.ChevronLeft}" Size="16" Foreground="{DynamicResource TextMuted}"/>
                </Button>
                <Rectangle Width="1" Height="24" Fill="{DynamicResource BorderLight}" Margin="8,0"/>
                <ComboBox x:Name="LangPicker"
                          Classes="ui-lang-select"
                          ItemsSource="{Binding Languages}"
                          SelectedIndex="{Binding SelectedLanguageIndex, Mode=TwoWay}"
                          SelectionChanged="OnLanguageChanged"
                          BorderThickness="0"
                          Background="Transparent"
                          VerticalAlignment="Center"/>

                <Rectangle Width="1" Height="24" Fill="{DynamicResource BorderLight}" Margin="8,0"/>

                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <TextBlock Classes="ui-nav-label" Text="Speed"/>
                    <Border BorderBrush="{DynamicResource BorderLight}" BorderThickness="1" CornerRadius="{DynamicResource RadiusSm}" Height="28">
                        <StackPanel Orientation="Horizontal">
                            <Button Classes="ui-step-btn" Content="–" Click="OnSpeedDown" Background="Transparent" BorderThickness="0"/>
                            <Rectangle Width="1" Fill="{DynamicResource BorderLight}"/>
                            <Border Width="32" Background="Transparent" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Speed, StringFormat={}{0:F1}}" Foreground="{DynamicResource TextSecondary}" FontSize="11" FontWeight="Medium" HorizontalAlignment="Center"/>
                            </Border>
                            <Rectangle Width="1" Fill="{DynamicResource BorderLight}"/>
                            <Button Classes="ui-step-btn" Content="+" Click="OnSpeedUp" Background="Transparent" BorderThickness="0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <Rectangle Width="1" Height="24" Fill="{DynamicResource BorderLight}" Margin="8,0"/>

                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <TextBlock Classes="ui-nav-label" Text="Auto"/>
                    <ToggleSwitch IsChecked="{Binding AutoSpeed}" OnContent="" OffContent="" MinWidth="0" Height="26" VerticalAlignment="Center"/>
                </StackPanel>

                <Rectangle Width="1" Height="24" Fill="{DynamicResource BorderLight}" Margin="8,0"/>

                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <TextBlock Classes="ui-nav-label" Text="Learning"/>
                    <ToggleSwitch IsChecked="{Binding Learning}" OnContent="" OffContent="" MinWidth="0" Height="26" VerticalAlignment="Center"/>
                </StackPanel>

                <Rectangle Width="1" Height="24" Fill="{DynamicResource BorderLight}" Margin="8,0"/>

                <Button Width="28" Height="28" CornerRadius="14" Background="Transparent" BorderThickness="0"
                        VerticalAlignment="Center" Click="OnToggleStatusBar"
                        ToolTip.Tip="Hide/show status bar">
                    <LucideIcon Kind="{x:Static lucide:LucideIconKind.ChevronDown}" Size="16" Foreground="{DynamicResource TextMuted}"/>
                </Button>
            </StackPanel>
        </Border>

        <Grid x:Name="MainGrid" ColumnDefinitions="*,5,320">
            <controls:DasherCanvas x:Name="DasherCanvas"
                                   Grid.Column="0"
                                   OutputText="{Binding OutputText, Mode=OneWayToSource}"/>
            
            <GridSplitter x:Name="MessageSplitter" Grid.Column="1"
                          Classes="pane-splitter"
                          Width="5"
                          ResizeDirection="Auto"/>
            
            <Border x:Name="MessagePane" Grid.Column="2"
                    Background="{DynamicResource SurfaceLight}" BorderBrush="{DynamicResource BorderLight}" BorderThickness="1,0,0,0">
                <Grid RowDefinitions="Auto, Auto, Auto, *">
                    <ScrollViewer Grid.Row="0" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled">
                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="10,6" Height="48">
                            <Button Width="32" Height="32" CornerRadius="16" Background="{DynamicResource ControlBg}" BorderThickness="0" VerticalAlignment="Center" ToolTip.Tip="Back">
                                <LucideIcon Kind="{x:Static lucide:LucideIconKind.ChevronLeft}" Size="16" Foreground="{DynamicResource TextMuted}"/>
                            </Button>

                            <Button Classes="ui-circle-btn" Click="OnToggleMode" ToolTip.Tip="Toggle pane position">
                                <LucideIcon Kind="{x:Static lucide:LucideIconKind.Eye}" Size="18" Foreground="{DynamicResource TextSecondary}"/>
                            </Button>

                            <Button Classes="ui-circle-btn" Click="OnQuickSpeak" ToolTip.Tip="Quick speak">
                                <LucideIcon Kind="{x:Static lucide:LucideIconKind.Volume2}" Size="18" Foreground="{DynamicResource TextSecondary}"/>
                            </Button>

                            <Button Classes="ui-circle-btn" Click="OnStopSpeak" ToolTip.Tip="Stop speaking">
                                <LucideIcon Kind="{x:Static lucide:LucideIconKind.CircleStop}" Size="18" Foreground="{DynamicResource TextSecondary}"/>
                            </Button>

                            <Rectangle Width="1" Height="20" Fill="{DynamicResource BorderLight}" VerticalAlignment="Center"/>

                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <Button Width="46" Height="44" CornerRadius="6" Background="{DynamicResource ControlBg}" BorderThickness="0" Click="OnCopySelection" ToolTip.Tip="Copy selection">
                                    <StackPanel Spacing="2" VerticalAlignment="Center">
                                        <LucideIcon Kind="{x:Static lucide:LucideIconKind.Copy}" Size="16" Foreground="{DynamicResource TextSecondary}"/>
                                        <TextBlock Text="Copy" FontSize="9" Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button Width="46" Height="44" CornerRadius="6" Background="{DynamicResource ControlBg}" BorderThickness="0" Click="OnCopyAll" ToolTip.Tip="Copy all text">
                                    <StackPanel Spacing="2" VerticalAlignment="Center">
                                        <LucideIcon Kind="{x:Static lucide:LucideIconKind.ClipboardCopy}" Size="16" Foreground="{DynamicResource TextSecondary}"/>
                                        <TextBlock Text="Copy a." FontSize="9" Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button Width="46" Height="44" CornerRadius="6" Background="{DynamicResource ControlBg}" BorderThickness="0" Click="OnPaste" ToolTip.Tip="Paste">
                                    <StackPanel Spacing="2" VerticalAlignment="Center">
                                        <LucideIcon Kind="{x:Static lucide:LucideIconKind.ClipboardPaste}" Size="16" Foreground="{DynamicResource TextSecondary}"/>
                                        <TextBlock Text="Paste" FontSize="9" Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>

                            <Rectangle Width="1" Height="20" Fill="{DynamicResource BorderLight}" VerticalAlignment="Center"/>

                            <Button Width="46" Height="44" CornerRadius="6" Background="{DynamicResource ControlBg}" BorderThickness="0" ToolTip.Tip="More options">
                                <StackPanel Spacing="2" VerticalAlignment="Center">
                                    <LucideIcon Kind="{x:Static lucide:LucideIconKind.EllipsisVertical}" Size="16" Foreground="{DynamicResource TextSecondary}"/>
                                    <TextBlock Text="More" FontSize="9" Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </ScrollViewer>

                    <Border Grid.Row="1" Height="1" Background="{DynamicResource BorderLight}"/>

                    <Border x:Name="GameTargetBar" Grid.Row="2" Margin="10,4"
                            IsVisible="False" CornerRadius="{DynamicResource RadiusSm}"
                            Background="{DynamicResource HighlightLight}" Padding="8,4">
                        <StackPanel>
                            <TextBlock x:Name="GameTargetText" FontSize="14" FontFamily="Consolas, Courier New, monospace"
                                       TextWrapping="Wrap" LineHeight="22"/>
                        </StackPanel>
                    </Border>

                    <TextBox x:Name="MessageArea" Grid.Row="3"
                             Classes="message-area"
                             Text="{Binding OutputText, Mode=TwoWay}"
                             IsReadOnly="True"/>
                </Grid>
            </Border>
        </Grid>
    </DockPanel>
</Window>
