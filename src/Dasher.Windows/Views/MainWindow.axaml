<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Dasher.Windows.ViewModels"
        xmlns:controls="using:Dasher.Windows.Controls"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="650"
        x:Class="Dasher.Windows.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Dasher"
        Width="900" Height="650"
        MinWidth="400" MinHeight="300"
        Background="{DynamicResource BgLight}"
        WindowStartupLocation="CenterScreen"
        Icon="/dasher.ico">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Window.Styles>
        <Style Selector="Border.top-bar">
            <Setter Property="Background" Value="{DynamicResource SurfaceLight}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderLight}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Height" Value="{DynamicResource ToolbarHeight}"/>
            <Setter Property="Padding" Value="16,0"/>
        </Style>
        <Style Selector="Border.top-bar Button.nav-btn">
            <Setter Property="Background" Value="{DynamicResource ControlBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="500"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="MinHeight" Value="36"/>
            <Setter Property="CornerRadius" Value="{DynamicResource RadiusSm}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Border.top-bar Button.nav-btn:pointerover">
            <Setter Property="Background" Value="{DynamicResource ControlBgHover}"/>
        </Style>
        <Style Selector="Border.top-bar Button.nav-btn.accent">
            <Setter Property="Background" Value="{DynamicResource DasherTeal}"/>
            <Setter Property="Foreground" Value="{DynamicResource DeepNavy}"/>
        </Style>
        <Style Selector="Border.top-bar Button.nav-btn.accent:pointerover">
            <Setter Property="Opacity" Value="0.85"/>
        </Style>
        <Style Selector="Border.prefs-bar">
            <Setter Property="Background" Value="{DynamicResource SurfaceLight}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderLight}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="16,0"/>
        </Style>
        <Style Selector="Border.prefs-bar Button.prefs-tab">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="500"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="CornerRadius" Value="{DynamicResource RadiusSm}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Border.prefs-bar Button.prefs-tab:pointerover">
            <Setter Property="Background" Value="{DynamicResource ControlBg}"/>
        </Style>
        <Style Selector="Border.prefs-bar Button.prefs-tab.active">
            <Setter Property="Background" Value="{DynamicResource ControlBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="Border.bottom-bar">
            <Setter Property="Background" Value="{DynamicResource SurfaceLight}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderLight}"/>
            <Setter Property="BorderThickness" Value="0,1,0,0"/>
            <Setter Property="Height" Value="{DynamicResource StatusBarHeight}"/>
            <Setter Property="Padding" Value="16,0"/>
        </Style>
        <Style Selector="TextBlock.ui-nav-label">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="500"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMuted}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.ui-step-btn">
            <Setter Property="Background" Value="{DynamicResource ControlBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="600"/>
            <Setter Property="MinWidth" Value="28"/>
            <Setter Property="MinHeight" Value="28"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="CornerRadius" Value="{DynamicResource RadiusSm}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.ui-step-btn:pointerover">
            <Setter Property="Background" Value="{DynamicResource ControlBgHover}"/>
        </Style>
        <Style Selector="Border.ui-value">
            <Setter Property="Background" Value="{DynamicResource ControlValue}"/>
            <Setter Property="CornerRadius" Value="{DynamicResource RadiusSm}"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="MinWidth" Value="36"/>
        </Style>
        <Style Selector="Border.ui-value TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="500"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>
        <Style Selector="ComboBox.ui-lang-select">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="500"/>
            <Setter Property="MinHeight" Value="28"/>
            <Setter Property="MinWidth" Value="160"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.ui-colour-dot">
            <Setter Property="Width" Value="18"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="CornerRadius" Value="9"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
        <Style Selector="TextBox.message-area">
            <Setter Property="Background" Value="{DynamicResource SurfaceLight}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontFamily" Value="Arial, Segoe UI, Helvetica Neue, sans-serif"/>
            <Setter Property="AcceptsReturn" Value="True"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16"/>
        </Style>
        <Style Selector="Button.mode-toggle">
            <Setter Property="Background" Value="{DynamicResource ControlBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="500"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="MinHeight" Value="28"/>
            <Setter Property="CornerRadius" Value="{DynamicResource RadiusSm}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.mode-toggle:pointerover">
            <Setter Property="Background" Value="{DynamicResource ControlBgHover}"/>
        </Style>
        <Style Selector="Button.mode-toggle.keyboard-active">
            <Setter Property="Background" Value="{DynamicResource DasherTeal}"/>
            <Setter Property="Foreground" Value="{DynamicResource DeepNavy}"/>
        </Style>
        <Style Selector="Border.prefs-content">
            <Setter Property="Background" Value="{DynamicResource BgLight}"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
        <Style Selector="Button.sidebar-btn">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="500"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="MinHeight" Value="36"/>
            <Setter Property="CornerRadius" Value="{DynamicResource RadiusSm}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.sidebar-btn:pointerover">
            <Setter Property="Background" Value="{DynamicResource HighlightLight}"/>
        </Style>
        <Style Selector="Button.sidebar-action">
            <Setter Property="Background" Value="{DynamicResource DasherTeal}"/>
            <Setter Property="Foreground" Value="{DynamicResource DeepNavy}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="600"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="MinHeight" Value="40"/>
            <Setter Property="CornerRadius" Value="{DynamicResource RadiusMd}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.sidebar-action:pointerover">
            <Setter Property="Opacity" Value="0.85"/>
        </Style>
    </Window.Styles>

    <DockPanel>
        <!-- Top bar -->
        <Border Classes="top-bar" DockPanel.Dock="Top">
            <DockPanel>
                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center"
                            HorizontalAlignment="Left">
                    <Button Classes="nav-btn" Content="New" Click="OnNew"/>
                    <Button Classes="nav-btn" Content="Open" Click="OnOpen"/>
                    <Button Classes="nav-btn" Content="Save" Click="OnSave"/>
                    <Button x:Name="BtnPlay" Classes="nav-btn" Content="Play" Click="OnPlay"/>
                    <Button Classes="nav-btn" Content="View stats" Click="OnStats"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center"
                            HorizontalAlignment="Right">
                    <Button x:Name="BtnMode" Classes="mode-toggle" Content="Keyboard"
                            Click="OnToggleMode"/>
                    <Button x:Name="BtnPrefs" Classes="nav-btn" Content="Prefs"
                            Click="OnTogglePrefs"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Prefs bar -->
        <StackPanel DockPanel.Dock="Top" IsVisible="{Binding IsPrefsVisible}">
            <Border Classes="prefs-bar">
                <Border x:Name="PrefsTabStrip" IsVisible="True">
                    <StackPanel x:Name="PrefsTabContainer" Orientation="Horizontal" Spacing="2" VerticalAlignment="Center"/>
                </Border>
            </Border>
            <Border x:Name="PrefsContentPanel" Classes="prefs-content" IsVisible="False"
                    Background="{DynamicResource BgLight}" BorderBrush="{DynamicResource BorderLight}" BorderThickness="0,0,0,1"
                    MaxHeight="320">
                <controls:SettingsPanel x:Name="SettingsPanel"/>
            </Border>
        </StackPanel>

        <!-- Bottom bar -->
        <Border Classes="bottom-bar" DockPanel.Dock="Bottom">
            <StackPanel Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                <ComboBox x:Name="LangPicker"
                          Classes="ui-lang-select"
                          ItemsSource="{Binding Languages}"
                          SelectedIndex="{Binding SelectedLanguageIndex, Mode=TwoWay}"
                          SelectionChanged="OnLanguageChanged"/>

                <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Classes="ui-nav-label" Text="Speed"/>
                    <Button Classes="ui-step-btn" Content="-" Click="OnSpeedDown"/>
                    <Border Classes="ui-value">
                        <TextBlock Text="{Binding Speed, StringFormat={}{0:F1}}"/>
                    </Border>
                    <Button Classes="ui-step-btn" Content="+" Click="OnSpeedUp"/>
                    <TextBlock Classes="ui-nav-label" Text="Auto"/>
                    <CheckBox IsChecked="{Binding AutoSpeed}" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Classes="ui-nav-label" Text="Colour"/>
                    <StackPanel x:Name="PaletteContainer" Orientation="Horizontal" Spacing="4"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Main content: canvas + sidebar editor -->
        <Grid x:Name="MainGrid" ColumnDefinitions="*,1,Auto">
            <controls:DasherCanvas x:Name="DasherCanvas"
                                   Grid.Column="0"
                                   OutputText="{Binding OutputText, Mode=OneWayToSource}"/>
            <Border x:Name="MessageSplitter" Grid.Column="1"
                    Background="{DynamicResource BorderLight}" Width="1"/>
            <Border x:Name="MessagePane" Grid.Column="2" MinWidth="220" MaxWidth="500"
                    Background="{DynamicResource SurfaceLight}" BorderBrush="{DynamicResource BorderLight}" BorderThickness="1,0,0,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Output"
                               FontSize="11" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextMuted}"
                               Margin="16,12,16,4"/>
                    <StackPanel DockPanel.Dock="Bottom" Spacing="2" Margin="8,4,8,8">
                        <Button Classes="sidebar-action" Content="Quick Speak" Click="OnQuickSpeak"/>
                        <Button Classes="sidebar-btn" Content="Copy All" Click="OnCopyAll"/>
                        <Button Classes="sidebar-btn" Content="Copy Selection" Click="OnCopySelection"/>
                        <Button Classes="sidebar-btn" Content="Paste" Click="OnPaste"/>
                    </StackPanel>
                    <TextBox Classes="message-area"
                             x:Name="MessageArea"
                             Text="{Binding OutputText, Mode=OneWay}"
                             IsReadOnly="True"/>
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>
</Window>
