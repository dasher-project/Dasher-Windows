<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:Dasher.Windows.Controls"
        xmlns:lucide="using:Lucide.Avalonia"
        x:Class="Dasher.Windows.Views.SettingsWindow"
        Title="Settings"
        Width="680" Height="560"
        MinWidth="500" MinHeight="400"
        CanResize="True"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BgLight}">

    <Window.Styles>
        <Style Selector="Border.tab-bar">
            <Setter Property="Background" Value="{DynamicResource SurfaceLight}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderLight}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="12,8"/>
        </Style>
        <Style Selector="Border.tab-bar Button.settings-tab">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Margin" Value="0,0,2,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style Selector="Border.tab-bar Button.settings-tab:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource ControlBgHover}"/>
        </Style>
        <Style Selector="Border.tab-bar Button.settings-tab.active /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource DasherTeal}"/>
        </Style>
        <Style Selector="Border.tab-bar Button.settings-tab.active TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource DeepNavy}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="Border.tab-bar Button.settings-tab.active LucideIcon">
            <Setter Property="Foreground" Value="{DynamicResource DeepNavy}"/>
        </Style>
        <Style Selector="Border.tab-bar Button.settings-tab TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Medium"/>
        </Style>
        <Style Selector="Border.tab-bar Button.settings-tab LucideIcon">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
        </Style>
    </Window.Styles>

    <DockPanel>
        <Border Classes="tab-bar" DockPanel.Dock="Top">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                <StackPanel x:Name="TabContainer" Orientation="Horizontal" Spacing="2"/>
            </ScrollViewer>
        </Border>

        <Border DockPanel.Dock="Bottom" Background="{DynamicResource SurfaceLight}"
                BorderBrush="{DynamicResource BorderLight}" BorderThickness="0,1,0,0"
                Padding="16,10">
            <Button x:Name="DoneButton" HorizontalAlignment="Right"
                    Content="Done" Padding="24,8" CornerRadius="6"
                    Background="{DynamicResource DasherTeal}"
                    Foreground="{DynamicResource DeepNavy}"
                    FontWeight="SemiBold" FontSize="13"
                    BorderThickness="0" Cursor="Hand"/>
        </Border>

        <ScrollViewer Padding="20,16" Background="{DynamicResource BgLight}">
            <controls:SettingsPanel x:Name="SettingsPanel"/>
        </ScrollViewer>
    </DockPanel>
</Window>
